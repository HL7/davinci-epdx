           a fhir:String ;
           fhir:v "CodeSystem"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/davinci-pdex/CodeSystem/PdexMultiMemberMatchResultCS> ;
         fhir:reference [ fhir:v "CodeSystem/PdexMultiMemberMatchResultCS" ]
       ] ;
       fhir:name [ fhir:v "PDex Multi-Member Match Result Code System" ] ;
       fhir:description [ fhir:v "Code set to describe the results group from a multi-member Match operation" ] ;
       fhir:example [
