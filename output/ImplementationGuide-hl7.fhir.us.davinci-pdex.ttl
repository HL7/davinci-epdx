         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/davinci-pdex/ValueSet/PDexPayerBenefitPaymentStatus> ;
         fhir:reference [ fhir:v "ValueSet/PDexPayerBenefitPaymentStatus" ]
       ] ;
       fhir:name [ fhir:v "PDex Payer Benefit Payment Status" ] ;
       fhir:description [ fhir:v "Indicates the in network or out of network payment status of the claim." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
