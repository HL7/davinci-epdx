           fhir:v "CodeSystem"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/davinci-pdex/CodeSystem/PDexPayerAdjudicationStatus> ;
         fhir:reference [ fhir:v "CodeSystem/PDexPayerAdjudicationStatus" ]
       ] ;
       fhir:name [ fhir:v "PDex Payer Adjudication Status" ] ;
       fhir:description [ fhir:v "Describes the various status fields used when payers adjudicate a claim, such as whether the claim was adjudicated in or out of network, if the provider was contracted or non-contracted for the service" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
