       ] ;
       fhir:name [ fhir:v "PDex Multi-Member Match Result Value Set" ] ;
       fhir:description [ fhir:v "Codes to describe the results group from a multi-member Match operation or Member Attribution Process." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
