       fhir:name [ fhir:v "ExplanationOfBenefit_ServiceDate" ] ;
       fhir:description [ fhir:v "Date of the service for the EOB. The service-date search parameter simplifies the search, since a client doesn't need to know that. For inpatient and outpatient institutional EOB dates they need to search by billablePeriod.period.start, for a pharmacy EOB by item.servicedDate, and for a professional and non-clinician EOB - by item.servicedPeriod.period.start." ] ;
