       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/davinci-pdex/SearchParameter/pdex-consent-provision-type> ;
         fhir:reference [ fhir:v "SearchParameter/pdex-consent-provision-type" ]
       ] ;
       fhir:name [ fhir:v "PDex Consent Provision Type Search Parameter" ] ;
       fhir:description [ fhir:v "Search for Consent resources by the provision type (deny or permit). Use provision-type=deny combined with provision-action=disclose to find members who have opted out of Provider Access data sharing." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/davinci-pdex/StructureDefinition/pdex-device> ;
         fhir:reference [ fhir:v "StructureDefinition/pdex-device" ]
       ] ;
       fhir:name [ fhir:v "PDex Device" ] ;
       fhir:description [ fhir:v "The PDex Device profile is provided to enable payers to record information about devices used by a member that may not have a UDI number. \nFHIR-29796 PDex Device uses base resource not US Core Implantable Device Profile. Pdex-Device enables payers to record non-implantable device data. CGP Voted on variance approval: Drew Torres/Eric Haas: 9-0-0" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "SearchParameter"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <http://hl7.org/fhir/us/davinci-pdex/SearchParameter/pdex-group-characteristic-value-reference> ;
         fhir:reference [ fhir:v "SearchParameter/pdex-group-characteristic-value-reference" ]
       ] ;
       fhir:name [ fhir:v "PDex Group Characteristic Value Reference Search Parameter" ] ;
       fhir:description [ fhir:v "Search for Group resources by the Reference value of a characteristic. Used to find PDex Member Match Groups and Provider Groups associated with a specific requesting payer or provider Organization (stored in characteristic.valueReference)." ] ;
