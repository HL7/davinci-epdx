         fhir:reference [ fhir:v "StructureDefinition/pdex-medicationdispense" ]
       ] ;
       fhir:name [ fhir:v "PDex MedicationDispense" ] ;
       fhir:description [ fhir:v "Prescription Medications dispensed by a pharmacy to a health plan member and paid for in full, or in part, by the health plan" ] ;
