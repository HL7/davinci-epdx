         fhir:reference [ fhir:v "StructureDefinition/base-ext-match-coverage" ]
       ] ;
       fhir:name [ fhir:v "Member-Match Input Coverage Parameter" ] ;
       fhir:description [ fhir:v "Input Coverage Parameter supplied for the individual member match. When the same patient is submitted with multiple different coverage plans, this optional extension allows the responder to include the submitted Coverage resource alongside the submitted Patient resource, enabling the requester to unambiguously identify which (patient + coverage) pair each Group member entry corresponds to." ] ;
