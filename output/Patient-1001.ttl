@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<http://hl7.org/fhir/us/davinci-pdex/Patient/1001> a fhir:Patient ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "1001"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://hl7.org/fhir/us/core/StructureDefinition/us-core-patient"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/us/core/StructureDefinition/us-core-patient>
     ] )
  ] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">Patient/1001. Default Generated text for resource.</div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:identifier ( [
     fhir:type [
       fhir:coding ( [
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/v2-0203"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/v2-0203>
         ] ;
         fhir:code [ fhir:v "MB" ]
       ] )
     ] ;
     fhir:system [
       fhir:v "http://example.org/old-payer/identifiers/member"^^xsd:anyURI ;
       fhir:l <http://example.org/old-payer/identifiers/member>
     ] ;
     fhir:value [ fhir:v "55678" ] ;
     fhir:assigner [
       fhir:display [ fhir:v "Old Payer" ]
     ]
  ] ) ; # 
  fhir:name ( [
     fhir:use [ fhir:v "official" ] ;
     fhir:family [ fhir:v "Person" ] ;
     fhir:given ( [ fhir:v "Patricia" ] [ fhir:v "Ann" ] )
  ] ) ; # 
  fhir:gender [ fhir:v "female"] ; # 
  fhir:birthDate [ fhir:v "1974-12-25"^^xsd:date] . # 

