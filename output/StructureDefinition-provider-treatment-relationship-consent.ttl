       fhir:path [ fhir:v "Consent.verification" ] ;
       fhir:short [ fhir:v "Verification of the treatment relationship attestation" ] ;
       fhir:definition [ fhir:v "Information about verification of the treatment relationship attestation" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
