       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.verification.verifiedWith" ] ;
       fhir:path [ fhir:v "Consent.verification.verifiedWith" ] ;
       fhir:short [ fhir:v "Who verified the attestation" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
