  fhir:differential [
     fhir:element ( [
       fhir:id [ fhir:v "Consent.status" ] ;
       fhir:path [ fhir:v "Consent.status" ] ;
       fhir:short [ fhir:v "Status of the treatment relationship attestation" ] ;
       fhir:definition [ fhir:v "Indicates whether this treatment relationship attestation is active, inactive, or has been entered in error" ] ;
       fhir:mustSupport [ fhir:v true ] ;
       fhir:binding [
         fhir:strength [ fhir:v "required" ] ;
         fhir:valueSet [
           fhir:v "http://hl7.org/fhir/us/davinci-pdex/ValueSet/attestation-status-valueset"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/us/davinci-pdex/ValueSet/attestation-status-valueset>
         ]
       ]
     ] [
       fhir:id [ fhir:v "Consent.scope" ] ;
       fhir:path [ fhir:v "Consent.scope" ] ;
       fhir:short [ fhir:v "Treatment relationship scope" ] ;
       fhir:definition [ fhir:v "Fixed to 'treatment' to indicate this consent represents a treatment relationship" ] ;
       fhir:pattern [
         a fhir:CodeableConcept ;
         fhir:coding ( [
           fhir:system [
             fhir:v "http://terminology.hl7.org/CodeSystem/consentscope"^^xsd:anyURI ;
             fhir:l <http://terminology.hl7.org/CodeSystem/consentscope>
           ] ;
           fhir:code [ fhir:v "treatment" ]
         ] )
       ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.category" ] ;
       fhir:path [ fhir:v "Consent.category" ] ;
       fhir:short [ fhir:v "Classification of consent (e.g., treatment relationship, attestation)" ] ;
       fhir:definition [ fhir:v "Classification of the type of consent. Should include codes indicating treatment relationship and attestation" ] ;
       fhir:mustSupport [ fhir:v true ] ;
       fhir:binding [
         fhir:strength [ fhir:v "extensible" ] ;
         fhir:valueSet [
           fhir:v "http://hl7.org/fhir/ValueSet/consent-category"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/ValueSet/consent-category>
         ]
       ]
     ] [
       fhir:id [ fhir:v "Consent.patient" ] ;
       fhir:path [ fhir:v "Consent.patient" ] ;
       fhir:short [ fhir:v "Patient who is the subject of the treatment relationship" ] ;
       fhir:definition [ fhir:v "Reference to the patient for whom the treatment relationship is being attested" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.dateTime" ] ;
       fhir:path [ fhir:v "Consent.dateTime" ] ;
       fhir:short [ fhir:v "Date/time when treatment relationship attestation was recorded" ] ;
       fhir:definition [ fhir:v "When this treatment relationship attestation was recorded or last updated" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.performer" ] ;
       fhir:path [ fhir:v "Consent.performer" ] ;
       fhir:short [ fhir:v "Practitioner, facility, or organization attesting to treatment relationship" ] ;
       fhir:definition [ fhir:v "The healthcare provider (practitioner, organization, or facility) attesting that they have a treatment relationship with the patient" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:type ( [
         fhir:code [
           fhir:v "Reference"^^xsd:anyURI ;
           fhir:l fhir:Reference
         ] ;
         fhir:targetProfile ( [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Practitioner"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/StructureDefinition/Practitioner>
         ] [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Organization"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/StructureDefinition/Organization>
         ] [
           fhir:v "http://hl7.org/fhir/StructureDefinition/PractitionerRole"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/StructureDefinition/PractitionerRole>
         ] )
       ] ) ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.organization" ] ;
       fhir:path [ fhir:v "Consent.organization" ] ;
       fhir:short [ fhir:v "Organization responsible for the treatment relationship" ] ;
       fhir:definition [ fhir:v "The healthcare organization under which this treatment relationship exists" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.source[x]" ] ;
       fhir:path [ fhir:v "Consent.source[x]" ] ;
       fhir:short [ fhir:v "Source of the attestation" ] ;
       fhir:definition [ fhir:v "Reference to the source document, system, or person who provided the attestation" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.policy" ] ;
       fhir:path [ fhir:v "Consent.policy" ] ;
       fhir:short [ fhir:v "Policies or regulations governing the treatment relationship" ] ;
       fhir:definition [ fhir:v "References to applicable policies, regulations, or legal frameworks governing treatment relationships" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
