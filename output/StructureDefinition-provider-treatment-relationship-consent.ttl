       fhir:path [ fhir:v "Consent.verification.verificationDate" ] ;
       fhir:short [ fhir:v "When the attestation was verified" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.provision" ] ;
       fhir:path [ fhir:v "Consent.provision" ] ;
       fhir:short [ fhir:v "Details of the treatment relationship" ] ;
       fhir:definition [ fhir:v "Detailed provisions about the scope, purpose, and period of the treatment relationship" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.provision.type" ] ;
       fhir:path [ fhir:v "Consent.provision.type" ] ;
       fhir:short [ fhir:v "Whether this is a permission (permit) or denial" ] ;
       fhir:definition [ fhir:v "For treatment relationships, this should typically be 'permit' indicating an active relationship" ] ;
       fhir:mustSupport [ fhir:v true ] ;
       fhir:binding [
         fhir:strength [ fhir:v "required" ] ;
         fhir:valueSet [
           fhir:v "http://hl7.org/fhir/us/davinci-pdex/ValueSet/attestation-provision-type-valueset"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/us/davinci-pdex/ValueSet/attestation-provision-type-valueset>
         ]
       ]
     ] [
       fhir:id [ fhir:v "Consent.provision.period" ] ;
       fhir:path [ fhir:v "Consent.provision.period" ] ;
       fhir:short [ fhir:v "Time period for the treatment relationship" ] ;
       fhir:definition [ fhir:v "The time period during which the treatment relationship is valid or was active" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.provision.period.start" ] ;
       fhir:path [ fhir:v "Consent.provision.period.start" ] ;
       fhir:short [ fhir:v "Start date of treatment relationship" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Consent.provision.actor" ] ;
       fhir:path [ fhir:v "Consent.provision.actor" ] ;
       fhir:short [ fhir:v "Actors involved in the treatment relationship" ] ;
