  fhir:text [
     fhir:status [ fhir:v "extensions" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet PDexPayerBenefitPaymentStatus</b></p><a name=\"PDexPayerBenefitPaymentStatus\"> </a><a name=\"hcPDexPayerBenefitPaymentStatus\"> </a><ul><li>Include these codes as defined in <a href=\"CodeSystem-PDexPayerAdjudicationStatus.html\"><code>http://hl7.org/fhir/us/davinci-pdex/CodeSystem/PDexPayerAdjudicationStatus</code></a><span title=\"Version is not explicitly stated, which means it is fixed to the version provided in this specification\"> version ?2.2.0</span><table class=\"none\"><tr><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a href=\"CodeSystem-PDexPayerAdjudicationStatus.html#PDexPayerAdjudicationStatus-innetwork\">innetwork</a></td><td>In Network</td><td>Indicates the claim or claim line was paid in network.  This does not indicate the contracting status of the provider</td></tr><tr><td><a href=\"CodeSystem-PDexPayerAdjudicationStatus.html#PDexPayerAdjudicationStatus-outofnetwork\">outofnetwork</a></td><td>Out Of Network</td><td>Indicates the claim or claim line was paid out of network.  This does not indicate the contracting status of the provider</td></tr><tr><td><a href=\"CodeSystem-PDexPayerAdjudicationStatus.html#PDexPayerAdjudicationStatus-other\">other</a></td><td>Other</td><td>Indicates other network status or when a network does not apply</td></tr></table></li></ul></div>"^^rdf:XMLLiteral ]
  ] ; # 
