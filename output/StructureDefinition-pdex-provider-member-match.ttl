         fhir:severity [ fhir:v "error" ] ;
         fhir:human [ fhir:v "Can only have members if group is \"actual\"" ] ;
         fhir:expression [ fhir:v "member.empty() or (actual = true)" ] ;
         fhir:xpath [ fhir:v "f:actual/@value=true() or not(exists(f:member))" ] ;
         fhir:source [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Group"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/StructureDefinition/Group>
