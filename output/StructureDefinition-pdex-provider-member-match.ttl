       fhir:short [ fhir:v "Submitted member demographics from provider" ] ;
       fhir:definition [ fhir:v "Contains the Patient resources submitted by the provider in the match request, allowing the payer to return both the matched Patient ID and the original submitted demographics." ]
     ] [
       fhir:id [ fhir:v "Group.identifier" ] ;
       fhir:path [ fhir:v "Group.identifier" ] ;
