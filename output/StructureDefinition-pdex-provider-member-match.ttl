       fhir:path [ fhir:v "Group.managingEntity" ] ;
       fhir:short [ fhir:v "Payer managing this group" ] ;
       fhir:definition [ fhir:v "Reference to the payer organization that performed the member match and is managing access" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Group.characteristic" ] ;
       fhir:path [ fhir:v "Group.characteristic" ] ;
