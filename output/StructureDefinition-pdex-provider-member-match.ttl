       fhir:pattern [
         a fhir:Boolean ;
         fhir:v true
       ]
     ] [
       fhir:id [ fhir:v "Group.code" ] ;
       fhir:path [ fhir:v "Group.code" ] ;
       fhir:short [ fhir:v "Match result code" ] ;
       fhir:definition [ fhir:v "Code indicating this is a successful match group" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ] ;
